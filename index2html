<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Balance">
<link rel="manifest" href="manifest.json">
<title>Balance</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;500;700&display=swap');
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--bg:#f5f0eb;--card:#fffdf9;--text:#4a3f35;--text-light:#8c7e72;--text-muted:#b5a99a;--border:#e8e0d6;--accent:#c4956a;--accent-light:#e8d5c0;--green:#7a9e7e;--red:#c47a7a;--shadow:0 2px 12px rgba(74,63,53,0.06)}
body{font-family:'Zen Maru Gothic','Noto Sans TC',-apple-system,sans-serif;background:var(--bg);max-width:480px;margin:0 auto;min-height:100vh;min-height:-webkit-fill-available;color:var(--text);overflow-x:hidden}

/* Nav */
.nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:var(--card);border-top:1px solid var(--border);display:flex;z-index:50;padding:6px 0;padding-bottom:calc(6px + env(safe-area-inset-bottom))}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:6px 0;border:none;background:none;color:var(--text-muted);font-size:10px;cursor:pointer;font-family:inherit;transition:.2s}
.nav-item.active{color:var(--accent)}
.nav-item .icon{font-size:22px}

/* Pages */
.page{display:none;padding:16px 16px 100px}
.page.active{display:block}

/* Common */
.card{background:var(--card);border-radius:14px;padding:16px;margin-bottom:12px;box-shadow:var(--shadow);border:1px solid var(--border)}
.card-title{font-size:13px;color:var(--text-light);margin-bottom:10px;font-weight:500}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-top:4px}
.header h1{font-size:22px;font-weight:700}
.header .sub{font-size:11px;color:var(--text-muted);margin-top:2px}
.settings-btn{width:34px;height:34px;border-radius:10px;border:1px solid var(--border);background:var(--card);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center}

/* Record page */
.mic-area{display:flex;flex-direction:column;align-items:center;padding:16px 0}
.mic-btn{width:72px;height:72px;border-radius:50%;border:3px solid var(--accent);background:var(--card);color:var(--accent);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:28px;transition:.3s;box-shadow:0 4px 20px rgba(196,149,106,0.15)}
.mic-btn.recording{background:var(--red);border-color:var(--red);color:#fff;animation:pulse 1.5s infinite;box-shadow:0 0 0 8px rgba(196,122,122,0.12)}
.mic-btn.processing{opacity:.5;pointer-events:none}
@keyframes pulse{0%,100%{box-shadow:0 0 0 8px rgba(196,122,122,0.12)}50%{box-shadow:0 0 0 16px rgba(196,122,122,0.06)}}
.mic-hint{margin-top:8px;font-size:12px;color:var(--text-muted)}
.transcript{margin:0 0 12px;padding:10px 14px;border-radius:10px;background:var(--card);border:1.5px dashed var(--accent-light);font-size:14px;display:none}
.transcript.show{display:block}
.manual{display:flex;gap:8px;margin-bottom:12px}
.manual input{flex:1;padding:10px 12px;border-radius:10px;border:1.5px solid var(--border);font-size:14px;outline:none;background:var(--card);font-family:inherit}
.manual input:focus{border-color:var(--accent)}
.manual input::placeholder{color:var(--text-muted)}
.manual button{padding:10px 16px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit}
.status{padding:8px 14px;margin-bottom:12px;border-radius:8px;font-size:12px;text-align:center;display:none}
.status.show{display:block}
.status.ok{background:rgba(122,158,126,0.12);color:var(--green)}
.status.err{background:rgba(196,122,122,0.12);color:var(--red)}
.status.info{background:rgba(196,149,106,0.12);color:var(--accent)}

.expense-card{background:var(--card);border-radius:12px;padding:12px 14px;margin-bottom:8px;box-shadow:var(--shadow);border-left:3px solid var(--accent);border-right:1px solid var(--border);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.expense-card.confirmed{opacity:.6}
.expense-top{display:flex;justify-content:space-between;align-items:flex-start}
.expense-name{display:flex;align-items:center;gap:6px;margin-bottom:3px}
.expense-name .desc{font-weight:600;font-size:14px}
.expense-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.tag{padding:1px 7px;border-radius:5px;font-size:11px;font-weight:500;background:var(--accent-light);color:var(--accent)}
.tag-dim{padding:1px 7px;border-radius:5px;font-size:11px;background:#f0ebe4;color:var(--text-muted)}
.exp-amount{font-size:20px;font-weight:700}
.exp-actions{display:flex;gap:6px;margin-top:10px;justify-content:flex-end}
.exp-actions button{padding:5px 10px;border-radius:8px;border:none;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;background:none}
.btn-del{color:var(--red)}.btn-edit{color:var(--accent)}.btn-ok{background:var(--green)!important;color:#fff}

/* Overview page */
.summary-row{display:flex;gap:10px;margin-bottom:12px}
.summary-item{flex:1;background:var(--card);border-radius:12px;padding:12px;border:1px solid var(--border);text-align:center}
.summary-item .label{font-size:11px;color:var(--text-muted);margin-bottom:4px}
.summary-item .value{font-size:20px;font-weight:700}
.summary-item .value.small{font-size:16px}
.period-tabs{display:flex;gap:4px;margin-bottom:12px}
.period-tab{flex:1;padding:6px;border-radius:8px;border:none;background:var(--card);color:var(--text-muted);font-size:12px;font-weight:500;cursor:pointer;text-align:center;font-family:inherit;border:1px solid var(--border)}
.period-tab.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.chart-container{display:flex;justify-content:center;padding:8px 0}
.legend{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.legend-item{display:flex;align-items:center;gap:4px;font-size:11px;color:var(--text-light)}
.legend-dot{width:10px;height:10px;border-radius:3px}
.pay-stat{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.pay-stat .name{font-size:12px;width:70px;text-align:right;color:var(--text-light);flex-shrink:0}
.pay-stat .bar{flex:1;height:14px;background:#f0ebe4;border-radius:7px;overflow:hidden}
.pay-stat .bar-fill{height:100%;border-radius:7px;transition:width .5s}
.pay-stat .amount{font-size:12px;font-weight:600;width:80px;text-align:right}

/* History page */
.record-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.record-row:last-child{border-bottom:none}
.record-desc{font-size:13px;font-weight:500}
.record-meta{font-size:11px;color:var(--text-muted);margin-top:2px}
.record-amount{font-size:14px;font-weight:700;white-space:nowrap}

/* Credit Card page */
.cc-card{background:var(--card);border-radius:14px;padding:14px;margin-bottom:10px;border:1px solid var(--border);cursor:pointer;transition:.2s}
.cc-card:active{transform:scale(0.98)}
.cc-card.selected{border-color:var(--accent);box-shadow:0 0 0 2px var(--accent-light)}
.cc-name{font-weight:600;font-size:15px}
.cc-cycle{font-size:11px;color:var(--text-muted);margin-top:2px}
.cc-total{font-size:18px;font-weight:700;margin-top:4px}
.cc-detail{margin-top:8px;background:#faf6f1;border-radius:10px;overflow:hidden}
.cc-detail-item{padding:10px 14px;display:flex;justify-content:space-between;border-bottom:1px solid var(--border);font-size:13px}
.cc-detail-item:last-child{border-bottom:none}

/* Modal */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.4);display:none;align-items:flex-end;justify-content:center;z-index:100}
.overlay.show{display:flex}
.modal{background:var(--card);border-radius:20px 20px 0 0;padding:24px;width:100%;max-width:480px;max-height:85vh;overflow-y:auto}
.modal h2{font-size:18px;font-weight:700;margin-bottom:16px}
.modal label{display:block;font-size:12px;font-weight:600;color:var(--text-light);margin:10px 0 4px}
.modal input,.modal select{width:100%;padding:10px 12px;border-radius:10px;border:1.5px solid var(--border);background:var(--bg);color:var(--text);font-size:14px;outline:none;font-family:inherit}
.modal input:focus,.modal select:focus{border-color:var(--accent)}
.modal .hint{font-size:11px;color:var(--text-muted);margin-top:2px}
.modal-actions{display:flex;gap:8px;margin-top:16px}
.modal-actions button{flex:1;padding:10px;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;border:none;font-family:inherit}
.btn-cancel{background:var(--bg);color:var(--text-light)}.btn-save{background:var(--accent);color:#fff}
.loading{text-align:center;padding:32px;color:var(--text-muted);font-size:13px}
</style>
</head>
<body>

<!-- Bottom Nav -->
<div class="nav">
  <button class="nav-item active" onclick="goPage(0)"><span class="icon">🎙</span>記帳</button>
  <button class="nav-item" onclick="goPage(1)"><span class="icon">📊</span>總覽</button>
  <button class="nav-item" onclick="goPage(2)"><span class="icon">💳</span>信用卡</button>
  <button class="nav-item" onclick="goPage(3)"><span class="icon">📋</span>紀錄</button>
</div>

<!-- Page 0: Record -->
<div class="page active" id="page0">
  <div class="header"><div><h1>Balance</h1><div class="sub">說一句話，自動入帳</div></div><button class="settings-btn" onclick="openSetup()">⚙</button></div>
  <div class="mic-area">
    <div style="display:flex;gap:20px;align-items:center">
      <button class="mic-btn" id="micBtn" onclick="toggleMic()">🎤</button>
      <button class="mic-btn" id="camBtn" onclick="document.getElementById('camInput').click()" style="background:var(--card);border:3px solid var(--green);color:var(--green);box-shadow:0 4px 20px rgba(122,158,126,0.15)">📷</button>
    </div>
    <input type="file" id="camInput" accept="image/*" capture="environment" style="display:none" onchange="handlePhoto(this)">
    <div class="mic-hint" id="micHint">🎤 語音 ｜ 📷 拍照</div>
  </div>
  <div id="photoPreview" style="display:none;margin:0 0 12px;text-align:center">
    <img id="photoImg" style="max-width:100%;max-height:200px;border-radius:10px;border:1px solid var(--border)">
  </div>
  <div class="transcript" id="transcript"></div>
  <div class="manual"><input type="text" id="manualInput" placeholder="午餐便當 80" onkeydown="if(event.key==='Enter')manualSubmit()"><button onclick="manualSubmit()">送出</button></div>
  <div class="status" id="statusBar"></div>
  <div id="expenseList"><div class="loading" id="emptyState">🎙️ 按下麥克風開始記帳</div></div>
</div>

<!-- Page 1: Overview -->
<div class="page" id="page1">
  <div class="header"><div><h1>支出總覽</h1></div><button class="settings-btn" onclick="loadSheetData()">🔄</button></div>
  <div class="period-tabs">
    <button class="period-tab" onclick="setPeriod('today',this)">今日</button>
    <button class="period-tab" onclick="setPeriod('week',this)">本週</button>
    <button class="period-tab active" onclick="setPeriod('month',this)">本月</button>
    <button class="period-tab" onclick="setPeriod('all',this)">全部</button>
  </div>
  <div id="yearSelector" style="display:none;align-items:center;justify-content:center;gap:12px;margin:-8px 0 12px">
    <button onclick="changeYear(-1)" style="border:none;background:var(--card);border-radius:8px;padding:4px 10px;font-size:16px;cursor:pointer;color:var(--accent);border:1px solid var(--border)">◀</button>
    <span id="yearLabel" style="font-size:15px;font-weight:600;min-width:50px;text-align:center"></span>
    <button onclick="changeYear(1)" style="border:none;background:var(--card);border-radius:8px;padding:4px 10px;font-size:16px;cursor:pointer;color:var(--accent);border:1px solid var(--border)">▶</button>
  </div>
  <div class="summary-row">
    <div class="summary-item"><div class="label">總支出</div><div class="value" id="ovTotal">$0</div></div>
    <div class="summary-item"><div class="label">筆數</div><div class="value small" id="ovCount">0</div></div>
    <div class="summary-item"><div class="label">日均</div><div class="value small" id="ovAvg">$0</div></div>
  </div>
  <div class="card"><div class="card-title">📊 分類比例</div><div class="chart-container"><canvas id="pieChart" width="200" height="200"></canvas></div><div class="legend" id="pieLegend"></div></div>
  <div class="card"><div class="card-title">💰 帳戶支出</div><div id="payStats"></div></div>
</div>

<!-- Page 2: Credit Cards -->
<div class="page" id="page2">
  <div class="header"><div><h1>信用卡帳單</h1><div class="sub">當期消費明細</div></div></div>
  <div id="ccList"></div>
  <div id="ccDetail"></div>
</div>

<!-- Page 3: History -->
<div class="page" id="page3">
  <div class="header"><div><h1>交易紀錄</h1></div></div>
  <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:10px">
    <button onclick="changeHistMonth(-1)" style="border:none;background:var(--card);border-radius:8px;padding:4px 10px;font-size:16px;cursor:pointer;color:var(--accent);border:1px solid var(--border)">◀</button>
    <span id="histMonthLabel" style="font-size:15px;font-weight:600;min-width:100px;text-align:center"></span>
    <button onclick="changeHistMonth(1)" style="border:none;background:var(--card);border-radius:8px;padding:4px 10px;font-size:16px;cursor:pointer;color:var(--accent);border:1px solid var(--border)">▶</button>
  </div>
  <div style="margin-bottom:12px">
    <input type="text" id="histSearch" placeholder="🔍 搜尋（例如 Kobo、全聯）" oninput="renderHistory()" style="width:100%;padding:10px 12px;border-radius:10px;border:1.5px solid var(--border);font-size:14px;outline:none;background:var(--card);font-family:inherit">
  </div>
  <div id="historyList"><div class="loading">點選「總覽」載入資料</div></div>
</div>

<!-- Setup Modal -->
<div class="overlay" id="setupModal"><div class="modal"><h2>⚙️ 設定</h2>
  <label>Cloudflare Worker URL</label><input type="url" id="cfgW" placeholder="https://balance-proxy.xxx.workers.dev"><p class="hint">解決 CORS 的轉發器</p>
  <label>Claude API Key</label><input type="password" id="cfgK" placeholder="sk-ant-..."><p class="hint">存在手機本地</p>
  <label>Google Apps Script URL</label><input type="url" id="cfgU" placeholder="https://script.google.com/macros/s/...">
  <label>驗證密碼 (Token)</label><input type="password" id="cfgT" placeholder="與 Apps Script 一致">
  <div class="modal-actions"><button class="btn-cancel" onclick="closeSetup()">取消</button><button class="btn-save" onclick="saveConfig()">儲存</button></div>
</div></div>

<!-- Edit Modal -->
<div class="overlay" id="editModal"><div class="modal"><h2>編輯</h2>
  <label>日期</label><input type="date" id="editDate">
  <label>項目</label><input type="text" id="editDesc">
  <label>金額</label><input type="number" id="editAmount">
  <label>帳戶</label>
  <select id="editPayment"><option>現金</option><option>合庫</option><option>永豐(23日結帳8日繳款)</option><option>匯豐卡(18日結帳8日付款)</option><option>樂天熊貓卡(5日結帳26日繳款)</option><option>玉山PI錢包(10日結帳26日繳款)</option><option>玉山國旅卡(10日結帳26日繳款)</option><option>國泰CUBE卡(8日結帳2日繳款)</option><option>富邦MOMO卡(8日結帳24日繳款)</option></select>
  <label>幣別</label>
  <select id="editCurrency"><option>新台幣</option><option>日幣</option><option>美金</option><option>歐元</option></select>
  <label>分類</label>
  <select id="editCategory"><option>外食</option><option>食材採買</option><option>電子書</option><option>子女教育</option><option>生活用品</option><option>健身運動</option><option>衣物</option><option>旅遊住宿</option><option>軟體訂閱</option><option>帳務轉帳</option><option>保健</option><option>圖書</option><option>交通</option><option>文具</option><option>美妝保養</option><option>保險</option><option>電信費</option><option>禮物</option><option>證件規費</option></select>
  <div style="display:flex;gap:8px">
    <div style="flex:1"><label>匯率</label><input type="number" id="editRate" step="0.01" placeholder="1"></div>
    <div style="flex:1"><label>台幣等值</label><input type="number" id="editTWD" placeholder="自動計算"></div>
  </div>
  <div class="modal-actions"><button class="btn-cancel" onclick="closeEdit()">取消</button><button class="btn-save" onclick="saveEdit()">儲存</button></div>
</div></div>

<script>
// === Constants ===
const ICONS={"外食":"🍜","食材採買":"🥬","電子書":"📱","子女教育":"🎓","生活用品":"🧴","健身運動":"💪","衣物":"👔","旅遊住宿":"✈️","軟體訂閱":"💻","帳務轉帳":"🔄","保健":"💊","圖書":"📚","交通":"🚗","文具":"✏️","美妝保養":"💄","保險":"🛡️","電信費":"📡","禮物":"🎁","證件規費":"📋"};
const PAY_COLORS={"現金":"#7a9e7e","合庫":"#6b8cae","永豐(23日結帳8日繳款)":"#9b7bb5","匯豐卡(18日結帳8日付款)":"#c47a7a","樂天熊貓卡(5日結帳26日繳款)":"#c4956a","玉山PI錢包(10日結帳26日繳款)":"#6aafb5","玉山國旅卡(10日結帳26日繳款)":"#7ab59e","國泰CUBE卡(8日結帳2日繳款)":"#b5a46a","富邦MOMO卡(8日結帳24日繳款)":"#b56a8c"};
const CAT_COLORS={"外食":"#c4956a","食材採買":"#7a9e7e","電子書":"#9b7bb5","子女教育":"#6b8cae","生活用品":"#6aafb5","健身運動":"#7ab59e","衣物":"#b5a46a","旅遊住宿":"#c49a6a","軟體訂閱":"#8b7bc4","帳務轉帳":"#8c7e72","保健":"#c47a7a","圖書":"#ae6b8c","交通":"#b56a8c","文具":"#9eb57a","美妝保養":"#c48fa0","保險":"#6a9eb5","電信費":"#8c8c8c","禮物":"#c49a9a","證件規費":"#a0956a"};
const CARDS=[
  {name:"匯豐卡",full:"匯豐卡(18日結帳8日付款)",close:18,pay:8},
  {name:"樂天熊貓卡",full:"樂天熊貓卡(5日結帳26日繳款)",close:5,pay:26},
  {name:"玉山PI錢包",full:"玉山PI錢包(10日結帳26日繳款)",close:10,pay:26},
  {name:"玉山國旅卡",full:"玉山國旅卡(10日結帳26日繳款)",close:10,pay:26},
  {name:"國泰CUBE卡",full:"國泰CUBE卡(8日結帳2日繳款)",close:8,pay:2},
  {name:"富邦MOMO卡",full:"富邦MOMO卡(8日結帳24日繳款)",close:8,pay:24},
  {name:"永豐",full:"永豐(23日結帳8日繳款)",close:23,pay:8},
];

let config=null,expenses=[],confirmedSet=new Set(),recording=false,processing=false,recognition=null,editIdx=null;
let sheetData=[],currentPeriod='month',selectedCard=null;
let selectedYear=new Date().getFullYear();
let histYear=new Date().getFullYear(),histMonth=new Date().getMonth()+1;

// === Navigation ===
function goPage(n){
  document.querySelectorAll('.page').forEach((p,i)=>p.classList.toggle('active',i===n));
  document.querySelectorAll('.nav-item').forEach((t,i)=>t.classList.toggle('active',i===n));
  if(n===1&&!sheetData.length)loadSheetData();
  if(n===2){if(!sheetData.length)loadSheetData().then(()=>renderCC());else renderCC();}
  if(n===3&&!sheetData.length)loadSheetData();
}

// === Config ===
function loadConfig(){try{const s=localStorage.getItem('balance-cfg');if(s){config=JSON.parse(s);return true;}}catch{}return false;}
function saveConfig(){const w=document.getElementById('cfgW').value.trim(),k=document.getElementById('cfgK').value.trim(),u=document.getElementById('cfgU').value.trim(),t=document.getElementById('cfgT').value.trim();if(!w||!k||!u||!t)return;config={workerUrl:w,claudeKey:k,sheetUrl:u,token:t};localStorage.setItem('balance-cfg',JSON.stringify(config));closeSetup();}
function openSetup(){if(config){document.getElementById('cfgW').value=config.workerUrl||'';document.getElementById('cfgK').value=config.claudeKey||'';document.getElementById('cfgU').value=config.sheetUrl||'';document.getElementById('cfgT').value=config.token||'';}document.getElementById('setupModal').classList.add('show');}
function closeSetup(){document.getElementById('setupModal').classList.remove('show');}

// === Local Date (UTC+8) ===
function getLocalDate(){const d=new Date();return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function fmtLocal(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}

// === Local Expenses ===
function genId(){return Date.now().toString(36)+Math.random().toString(36).slice(2,6);}
function loadExpenses(){try{const s=localStorage.getItem('bal-exp-'+getLocalDate());if(s){const d=JSON.parse(s);expenses=d.e||[];confirmedSet=new Set(d.c||[]);}}catch{}}
function saveExpenses(){localStorage.setItem('bal-exp-'+getLocalDate(),JSON.stringify({e:expenses,c:[...confirmedSet]}));}

// === Status ===
function showStatus(m,t){const el=document.getElementById('statusBar');el.textContent=m;el.className='status show '+t;setTimeout(()=>el.classList.remove('show'),3000);}

// === Render Expenses ===
function renderExpenses(){
  const list=document.getElementById('expenseList'),empty=document.getElementById('emptyState');
  list.querySelectorAll('.expense-card').forEach(c=>c.remove());
  if(!expenses.length){empty.style.display='block';return;}
  empty.style.display='none';
  expenses.forEach((item,idx)=>{
    const color=PAY_COLORS[item.payment]||'#c4956a',icon=ICONS[item.category]||'📌',isCon=confirmedSet.has(item._id);
    const card=document.createElement('div');card.className='expense-card'+(isCon?' confirmed':'');card.style.borderLeftColor=color;
    const shortPay=item.payment.replace(/\(.*\)/,'').trim();
    const curShow=item.currency!=='新台幣'?`<span class="tag-dim">${item.currency}</span>`:'';
    const acts=isCon?`<div style="text-align:right;margin-top:6px;font-size:11px;color:var(--green)">✓ 已入帳</div>`:`<div class="exp-actions"><button class="btn-del" onclick="deleteExpense(${idx})">刪除</button><button class="btn-edit" onclick="openEdit(${idx})">編輯</button><button class="btn-ok" onclick="confirmExpense(${idx})">✓ 入帳</button></div>`;
    card.innerHTML=`<div class="expense-top"><div><div class="expense-name"><span>${icon}</span><span class="desc">${item.description}</span></div><div class="expense-tags"><span class="tag" style="background:${color}18;color:${color}">${shortPay}</span><span class="tag-dim">${item.date}</span>${curShow}</div></div><div class="exp-amount">${item.currency==='新台幣'?'$':''}${Number(item.amount).toLocaleString()}</div></div>${acts}`;
    list.appendChild(card);
  });
}

// === Speech ===
function toggleMic(){
  if(processing)return;if(recording){recognition?.stop();return;}
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR){showStatus('不支援語音辨識','err');return;}
  recognition=new SR();recognition.lang='zh-TW';recognition.continuous=false;recognition.interimResults=true;let ft='';
  recognition.onresult=e=>{ft=Array.from(e.results).map(r=>r[0].transcript).join('');document.getElementById('transcript').textContent=ft;document.getElementById('transcript').classList.add('show');};
  recognition.onend=()=>{recording=false;document.getElementById('micBtn').classList.remove('recording');document.getElementById('micHint').textContent='點擊開始說話';if(ft)parseWithClaude(ft);};
  recognition.onerror=e=>{recording=false;document.getElementById('micBtn').classList.remove('recording');document.getElementById('micHint').textContent='點擊開始說話';showStatus('語音錯誤: '+e.error,'err');};
  recording=true;ft='';document.getElementById('micBtn').classList.add('recording');document.getElementById('micHint').textContent='說話中...點擊停止';document.getElementById('transcript').classList.remove('show');recognition.start();
}

