// === Load Sheet Data ===
async function loadSheetData(){
  if(!config?.sheetUrl||!config?.token){showStatus('請先設定','err');return;}
  document.getElementById('historyList').innerHTML='<div class="loading">載入中...</div>';
  try{
    const resp=await fetch(config.sheetUrl+'?token='+encodeURIComponent(config.token));
    const data=await resp.json();
    sheetData=data.map(r=>({date:normalizeDate(r['日期']||r.date||''),description:r['項目']||r.description||'',amount:parseFloat(String(r['金額']||r.amount||0).replace(/,/g,'')),payment:r['付款方式']||r.payment||'',currency:r['幣別']||r.currency||'新台幣',category:r['分類']||r.category||'外食',rate:parseFloat(r['匯率']||r.rate||1)||1,amountTWD:parseFloat(String(r['台幣等值']||r.amountTWD||0).replace(/,/g,''))||0})).filter(r=>r.amount&&!isNaN(r.amount));
    // If amountTWD is 0, calculate from amount*rate
    sheetData.forEach(r=>{if(!r.amountTWD)r.amountTWD=Math.round(r.amount*r.rate);});
    renderOverview();renderHistory();renderCC();
  }catch(err){document.getElementById('historyList').innerHTML='<div class="loading">載入失敗：'+err.message+'</div>';}
}
function normalizeDate(d){
  if(!d)return'';
  const s=String(d);
  // 2026年4月2日
  const m1=s.match(/(\d{4})年(\d{1,2})月(\d{1,2})日/);
  if(m1)return m1[1]+'-'+m1[2].padStart(2,'0')+'-'+m1[3].padStart(2,'0');
  // 2026-04-02 or 2026/04/02 or 2026/4/2
  const m2=s.match(/(\d{4})[-\/](\d{1,2})[-\/](\d{1,2})/);
  if(m2)return m2[1]+'-'+m2[2].padStart(2,'0')+'-'+m2[3].padStart(2,'0');
  // "Thu Apr 02 2026" or similar - extract from Date but use UTC to avoid timezone shift
  const dt=new Date(s);
  if(!isNaN(dt)){
    // Use the date parts directly to avoid timezone issues
    const y=dt.getFullYear(),mo=dt.getMonth()+1,da=dt.getDate();
    return y+'-'+String(mo).padStart(2,'0')+'-'+String(da).padStart(2,'0');
  }
  return s;
}

