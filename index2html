function getFilteredData(){
  const now=new Date(),today=getLocalDate(),dow=now.getDay()||7,ws=new Date(now);ws.setDate(now.getDate()-dow+1);const ms=new Date(now.getFullYear(),now.getMonth(),1);
  return sheetData.filter(r=>{if(r.category==='帳務轉帳')return false;const d=r.date;if(currentPeriod==='today')return d===today;if(currentPeriod==='week')return d>=fmtLocal(ws)&&d<=today;if(currentPeriod==='month')return d>=fmtLocal(ms)&&d<=today;if(currentPeriod==='all')return d.startsWith(selectedYear+'-');return true;});
}
function renderOverview(){
  const data=getFilteredData(),total=data.reduce((s,r)=>s+r.amountTWD,0),count=data.length;
  let days=1;if(currentPeriod==='week')days=new Date().getDay()||7;else if(currentPeriod==='month')days=new Date().getDate();else if(currentPeriod==='all'){const now=new Date();if(selectedYear===now.getFullYear()){const start=new Date(selectedYear,0,1);days=Math.max(1,Math.round((now-start)/86400000));}else{days=365;}}
  document.getElementById('ovTotal').textContent='$'+Math.round(total).toLocaleString();
  document.getElementById('ovCount').textContent=count;
  document.getElementById('ovAvg').textContent='$'+Math.round(days>0?total/days:0).toLocaleString();
  const catMap={};data.forEach(r=>{catMap[r.category]=(catMap[r.category]||0)+r.amountTWD;});drawPie(catMap);
  const payMap={};data.forEach(r=>{payMap[r.payment]=(payMap[r.payment]||0)+r.amountTWD;});renderPayStats(payMap);
}
function drawPie(catMap){
  const canvas=document.getElementById('pieChart'),ctx=canvas.getContext('2d'),entries=Object.entries(catMap).sort((a,b)=>b[1]-a[1]),total=entries.reduce((s,e)=>s+e[1],0);
  ctx.clearRect(0,0,200,200);const cx=100,cy=100,r=85;
  if(total===0){ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.fillStyle='#e8e0d6';ctx.fill();ctx.fillStyle='#b5a99a';ctx.font='13px "Zen Maru Gothic"';ctx.textAlign='center';ctx.fillText('尚無資料',cx,cy+5);document.getElementById('pieLegend').innerHTML='';return;}
  let sa=-Math.PI/2;entries.forEach(([cat,val])=>{const sl=(val/total)*Math.PI*2;ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,sa,sa+sl);ctx.closePath();ctx.fillStyle=CAT_COLORS[cat]||'#b5a99a';ctx.fill();sa+=sl;});
  ctx.beginPath();ctx.arc(cx,cy,50,0,Math.PI*2);ctx.fillStyle='#fffdf9';ctx.fill();
  ctx.fillStyle='#4a3f35';ctx.font='bold 16px "Zen Maru Gothic"';ctx.textAlign='center';ctx.fillText('$'+Math.round(total).toLocaleString(),cx,cy+1);
  ctx.fillStyle='#8c7e72';ctx.font='10px "Zen Maru Gothic"';ctx.fillText('合計',cx,cy+16);
  document.getElementById('pieLegend').innerHTML=entries.map(([cat,val])=>{const icon=ICONS[cat]||'📌';return`<div class="legend-item"><div class="legend-dot" style="background:${CAT_COLORS[cat]||'#b5a99a'}"></div>${icon} ${cat} ${Math.round(val/total*100)}%</div>`;}).join('');
}
function renderPayStats(payMap){
  const el=document.getElementById('payStats'),entries=Object.entries(payMap).sort((a,b)=>b[1]-a[1]),max=entries.length>0?entries[0][1]:1;
  if(!entries.length){el.innerHTML='<div class="loading">尚無資料</div>';return;}
  el.innerHTML=entries.map(([pay,val])=>{const pct=Math.round(val/max*100),color=PAY_COLORS[pay]||'#c4956a',short=pay.replace(/\(.*\)/,'').trim();return`<div class="pay-stat"><div class="name">${short}</div><div class="bar"><div class="bar-fill" style="width:${pct}%;background:${color}"></div></div><div class="amount">$${Math.round(val).toLocaleString()}</div></div>`;}).join('');
}

// === Credit Cards ===
function getBillingPeriod(closeDay){const now=new Date(),y=now.getFullYear(),m=now.getMonth(),d=now.getDate();let s,e;if(d<=closeDay){s=new Date(y,m-1,closeDay+1);e=new Date(y,m,closeDay);}else{s=new Date(y,m,closeDay+1);e=new Date(y,m+1,closeDay);}return{start:s,end:e};}
function fmtD(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function renderCC(){
  const list=document.getElementById('ccList'),det=document.getElementById('ccDetail');
  if(!sheetData.length){list.innerHTML='<div class="loading">載入中...</div>';det.innerHTML='';return;}
  let h='';
  CARDS.forEach(card=>{
    const p=getBillingPeriod(card.close);
    const items=sheetData.filter(r=>r.payment===card.full&&(()=>{const d=new Date(r.date);return d>=p.start&&d<=p.end;})());
    const total=items.reduce((s,r)=>s+Math.abs(r.amountTWD),0);
    const sel=selectedCard===card.full?' selected':'';
    const color=PAY_COLORS[card.full]||'#c4956a';
    h+=`<div class="cc-card${sel}" onclick="selCard('${card.full}')"><div style="display:flex;justify-content:space-between;align-items:center"><div><div class="cc-name" style="color:${color}">${card.name}</div><div class="cc-cycle">結帳 ${card.close}日 ｜繳款 ${card.pay}日　${fmtD(p.start)} ~ ${fmtD(p.end)}</div></div><div class="cc-total" style="color:${color}">$${total.toLocaleString()}</div></div></div>`;
  });
  list.innerHTML=h;renderCCDetail();
}
function selCard(f){selectedCard=selectedCard===f?null:f;renderCC();}
function renderCCDetail(){
  const det=document.getElementById('ccDetail');if(!selectedCard||!sheetData.length){det.innerHTML='';return;}
  const card=CARDS.find(c=>c.full===selectedCard);if(!card)return;
  const p=getBillingPeriod(card.close);
  const items=sheetData.filter(r=>r.payment===card.full&&(()=>{const d=new Date(r.date);return d>=p.start&&d<=p.end;})()).sort((a,b)=>b.date.localeCompare(a.date));
  if(!items.length){det.innerHTML='<div class="loading">當期無交易</div>';return;}
  let h='<div class="cc-detail">';
  items.forEach(r=>{const icon=ICONS[r.category]||'📌';const isForeign=r.currency!=='新台幣';const amtDisplay=isForeign?`${r.currency} ${Math.abs(r.amount).toLocaleString()}<br><span style="font-size:11px;color:var(--text-muted)">≈$${Math.abs(r.amountTWD).toLocaleString()}</span>`:`$${Math.abs(r.amountTWD).toLocaleString()}`;h+=`<div class="cc-detail-item"><div>${icon} ${r.description}<br><span style="font-size:11px;color:var(--text-muted)">${r.date} · ${r.category}</span></div><div style="font-weight:600;text-align:right">${amtDisplay}</div></div>`;});
  det.innerHTML=h+'</div>';
}

// === History ===
function changeHistMonth(delta){
  histMonth+=delta;
  if(histMonth>12){histMonth=1;histYear++;}
  if(histMonth<1){histMonth=12;histYear--;}
  updateHistLabel();
  renderHistory();
}
function updateHistLabel(){
  document.getElementById('histMonthLabel').textContent=histYear+'年'+histMonth+'月';
}
function renderHistory(){
  updateHistLabel();
  const el=document.getElementById('historyList');
  const keyword=(document.getElementById('histSearch')?.value||'').trim().toLowerCase();
  const ym=histYear+'-'+String(histMonth).padStart(2,'0');

  let filtered=sheetData.filter(r=>r.date.startsWith(ym));
  if(keyword){filtered=filtered.filter(r=>r.description.toLowerCase().includes(keyword)||r.payment.toLowerCase().includes(keyword)||r.category.toLowerCase().includes(keyword));}
  const sorted=filtered.sort((a,b)=>b.date.localeCompare(a.date));

  if(!sorted.length){el.innerHTML='<div class="loading">'+(keyword?'找不到「'+keyword+'」的紀錄':'本月無紀錄')+'</div>';return;}

  let lastDate='',html='',monthTotal=0;
  sorted.forEach(r=>{
    if(r.date!==lastDate){lastDate=r.date;html+=`<div style="font-size:12px;color:var(--text-muted);font-weight:600;margin-top:12px;margin-bottom:4px">${r.date}</div>`;}
    const icon=ICONS[r.category]||'📌',isForeign=r.currency!=='新台幣';
    const amtText=isForeign?`${r.currency} ${Math.round(r.amount).toLocaleString()} ≈$${Math.round(r.amountTWD).toLocaleString()}`:`$${Math.round(r.amountTWD).toLocaleString()}`;
    html+=`<div class="record-row"><div><div class="record-desc">${icon} ${r.description}</div><div class="record-meta">${r.payment.replace(/\(.*\)/,'').trim()} · ${r.category}</div></div><div class="record-amount">${amtText}</div></div>`;
    if(r.category!=='帳務轉帳')monthTotal+=r.amountTWD;
  });
  const summary=`<div style="text-align:center;padding:12px;font-size:13px;color:var(--text-light)">${sorted.length} 筆 ｜ 合計 $${Math.round(monthTotal).toLocaleString()}</div>`;
  el.innerHTML=summary+'<div class="card">'+html+'</div>';
}

// === Init ===
window.addEventListener('DOMContentLoaded',()=>{if(!loadConfig())openSetup();loadExpenses();renderExpenses();});
</script>
